            $sql = "INSERT INTO bookings (user_id, service_id, event_date, notes, status) VALUES ('$user_id', '$service_id', '$event_date', '$notes', 'pending')";
            if (mysqli_query($conn, $sql)) {
                $message = "<div style='color: #d4af37; margin-bottom: 20px; font-weight: bold;'>✨ Reservation requested successfully!</div>";
            }
        }
    }
}

if (isset($_POST['submit_review'])) {
    $rev_name = mysqli_real_escape_string($conn, $_POST['rev_name']);
    $rev_rating = intval($_POST['rev_rating']);
    $rev_comment = mysqli_real_escape_string($conn, $_POST['rev_comment']);
    if (!empty($rev_name) && !empty($rev_comment)) {
        mysqli_query($conn, "INSERT INTO comment (name, rating, comment) VALUES ('$rev_name', '$rev_rating', '$rev_comment')");
    }
}

$services_result = mysqli_query($conn, "SELECT id, name FROM services");
$booked_dates_query = mysqli_query($conn, "SELECT event_date FROM bookings ORDER BY event_date ASC LIMIT 5");
